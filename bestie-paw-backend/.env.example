# Database
DATABASE_URL="postgresql://user:password@localhost:5432/bestiepaw"

# JWT
JWT_ACCESS_SECRET="your-access-secret-min-32-chars"
JWT_REFRESH_SECRET="your-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Email (Nodemailer)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your@gmail.com"
SMTP_PASS="your-app-password"
MAIL_FROM="Bestie Paw <no-reply@bestiepaw.com>"

# Server
PORT=3000
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"

# Uploads
UPLOAD_DIR="./uploads"
UPLOAD_PUBLIC_BASE_URL=""
MAX_FILE_SIZE_MB=10

# Auth
REFRESH_SINGLE_DEVICE=true
TERMS_VERSION=2026-05

# OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

APPLE_CLIENT_ID=your-apple-client-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY_PATH=./apple-private-key.p8
APPLE_CALLBACK_URL=http://localhost:3000/api/auth/apple/callback
